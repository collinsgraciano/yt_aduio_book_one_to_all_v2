# ═══════════════════════════════════════════════
# 有声书 YouTube 频道管理系统 — 环境变量配置
# ═══════════════════════════════════════════════
# 使用方法：cp .env.example .env，然后修改对应的值

# ─── 数据库 ───
# Docker 内置 PostgreSQL 的密码（首次启动时创建）
POSTGRES_PASSWORD=your_strong_password_here

# ─── Web 服务 ───
# 用于加密 OAuth Secret 等敏感数据的密钥（建议 64 位随机字符串）
# 生成方法：openssl rand -hex 32
SECRET_KEY=generate_a_random_64_char_string

# Web 界面访问地址（用于 OAuth 回调，需与 Google Cloud Console 中配置一致）
BASE_URL=http://localhost:59386

# Web 界面登录密码（默认 inriynisse）
# APP_PASSWORD=inriynisse

# ─── HF 外包中继 ───
# HF 统一 Worker 地址（逗号分隔，可多个实现并行）
# 部署 HF Space 后填入，如：https://youruser-audiobook-worker-1.hf.space
WORKER_URLS=

# 中继管理面板密码（可选，留空=无密码）
# RELAY_WEB_PASSWORD=
